# 로컬 실행 환경변수. 커밋 금지.
KRONEX_API_BASE_URL=http://localhost:3000/api # REST API 주소
KRONEX_WS_URL=ws://localhost:3001/stock # 실시간 WS 주소
BOT_ACCESS_TOKEN= # 봇 인증 토큰
BOT_STOCK_IDS=1, 900002, 900003, 900004 # 병렬 실행 종목 ID 목록(쉼표 구분)
BOT_LOG_FILE=logs/bot-events.jsonl # JSONL 로그 경로
BOT_BUY_ACCOUNT_ID=1 # 매수 계좌 ID
BOT_BUY_ACCOUNT_NUMBER=10001 # 매수 주문 계좌번호
BOT_SELL_ACCOUNT_ID=2 # 매도 계좌 ID
BOT_SELL_ACCOUNT_NUMBER=10002 # 매도 주문 계좌번호

BOT_ORDER_REFERENCE_PRICE=7500 # 주문금액 스케일 기준가격(원)
BOT_ORDER_PRICE_DECAY_EXPONENT=0.3 # 가격 상승시 주문금액 감쇠계수(0~1)
BOT_MAX_ORDER_NOTIONAL=10000000 # 기준가격에서 전체 주문 최대금액(원)

BOT_FAIR_RANDOM_DELTA_MIN=-1 # FairPrice 랜덤 변동 최소 비율(%)
BOT_FAIR_RANDOM_DELTA_MAX=1 # FairPrice 랜덤 변동 최대 비율(%)
BOT_FAIR_INTERVAL_MS=3000 # FairPrice 일반 워커 주기(ms)
BOT_FAIR_EVENT_INTERVAL_MS=300000 # FairPrice 이벤트 워커 주기(ms)
BOT_FAIR_EVENT_RATE_MIN_PCT=-10 # FairPrice 이벤트 최소 변동률(%)
BOT_FAIR_EVENT_RATE_MAX_PCT=10 # FairPrice 이벤트 최대 변동률(%)

BOT_MM_CHECK_INTERVAL_MS=100 # 마켓메이커 호가 확인 주기(ms)
BOT_MM_ORDER_INTERVAL_MS=50 # 마켓메이커 주문 최소 간격(ms)
BOT_MM_MIN_ORDER_NOTIONAL=2000000 # 기준가격에서 마켓메이커 최소 주문금액(원)
BOT_MM_MAX_ORDER_NOTIONAL=5000000 # 기준가격에서 마켓메이커 최대 주문금액(원)

BOT_NOISE_MIN_INTERVAL_MS=100 # 노이즈테이커 최소 주문 간격(ms)
BOT_NOISE_MAX_INTERVAL_MS=150 # 노이즈테이커 최대 주문 간격(ms)
BOT_NOISE_MIN_ORDER_NOTIONAL=7500 # 기준가격에서 노이즈테이커 최소 주문금액(원)
BOT_NOISE_MAX_ORDER_NOTIONAL=1500000 # 기준가격에서 노이즈테이커 최대 주문금액(원)
BOT_NOISE_MIN_SIDE_PROBABILITY_PCT=15 # 노이즈테이커 한쪽 방향 최소 확률(%)
BOT_NOISE_MAX_SIDE_PROBABILITY_PCT=85 # 노이즈테이커 한쪽 방향 최대 확률(%)
BOT_NOISE_FULL_BIAS_DIVERGENCE_PCT=7 # 노이즈테이커 최대 확률 도달 괴리율(%)

BOT_MOMENTUM_INTERVAL_MS=450 # 모멘텀봇 주문 확인 주기(ms)
BOT_MOMENTUM_MIN_ORDER_NOTIONAL=7500 # 기준가격에서 모멘텀봇 최소 주문금액(원)
BOT_MOMENTUM_MAX_ORDER_NOTIONAL=2500000 # 기준가격에서 모멘텀봇 최대 주문금액(원)

BOT_REVERSION_MIN_INTERVAL_MS=450 # 평균회귀봇 최소 주문 간격(ms)
BOT_REVERSION_MAX_INTERVAL_MS=850 # 평균회귀봇 최대 주문 간격(ms)
BOT_REVERSION_MIN_ORDER_NOTIONAL=7500 # 기준가격에서 평균회귀봇 최소 주문금액(원)
BOT_REVERSION_MAX_ORDER_NOTIONAL=5000000 # 기준가격에서 평균회귀봇 최대 주문금액(원)
