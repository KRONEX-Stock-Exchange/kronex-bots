# 공통 연결 설정: 모든 봇이 REST 주문과 WebSocket 구독에 사용
KRONEX_API_BASE_URL=http://localhost:3001/api # 백엔드 REST API 주소
KRONEX_WS_URL=http://localhost:3001/stock # Socket.IO WebSocket 주소
BOT_ACCESS_TOKEN=replace_with_access_token # 봇 계정 Access Token

# 공통 거래 대상/계좌 설정: 세 봇 모두 동일하게 사용
BOT_STOCK_ID=1 # 봇이 거래할 단일 종목 ID
BOT_BUY_ACCOUNT_ID=1 # 매수 전용 계좌 ID
BOT_BUY_ACCOUNT_NUMBER=10001 # 매수 전용 계좌번호
BOT_SELL_ACCOUNT_ID=2 # 매도 전용 계좌 ID
BOT_SELL_ACCOUNT_NUMBER=10002 # 매도 전용 계좌번호
BOT_DRY_RUN=true # true면 주문 로그만 출력, false면 실제 주문 제출

# npm run bot:fill 설정: 현재가 기준 +-호가 중 완전히 빈 가격만 지정가로 채움
FILL_INTERVAL_MS=1000 # 호가창 채움 봇 확인 주기(ms)
FILL_LEVELS_EACH_SIDE=10 # 현재가 기준 위/아래로 확인할 호가 수
FILL_MAX_ORDERS_PER_TICK=1 # 한 주기당 최대 주문 수

# npm run bot:random 설정: 매수/매도를 랜덤으로 골라 시장가 주문 제출
RANDOM_ORDER_INTERVAL_MS=1000 # 무작위 시장가 주문 봇 주문 주기(ms)

# npm run bot:range-fill 설정: 상장 초기 전 호가 물량을 1회 세팅하고 종료
# RANGE_LOWER_PRICE=8000 # 범위 채움 봇 하단 가격
# RANGE_UPPER_PRICE=12000 # 범위 채움 봇 상단 가격
# RANGE_CENTER_PRICE=10000 # 이 가격까지 매수, 이 가격부터 매도 주문 세팅

# 공통 수량 계산 설정: 세 봇 모두 주문 수량 산정에 사용
BOT_QUANTITY_REFERENCE_PRICE=10000 # 수량 계산 기준 가격
BOT_QUANTITY_MIN_AT_REFERENCE=35 # 기준 가격에서 최소 수량
BOT_QUANTITY_MAX_AT_REFERENCE=1000 # 기준 가격에서 최대 수량
